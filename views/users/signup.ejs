<% layout("/layouts/boilerplate.ejs") %>

<div class="row mt-3 shadow rounded-4 w-50 mx-auto mb-3">
    <h3 class=" text-center col-10 offset-1 mt-3 mb-0">Create your account</h3>
    <p class=" text-center col-10 offset-1 small"  >Join <a href="/listings" class="text-decoration-none text-danger">StayNest</a> and start exploring</p>

  <div class="col-10 offset-1">
    <form action="/signup" method="POST" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input
          type="text"
          class="form-control"
          name="username"
          id="username"
          required
        />
        <div class="valid-feedback">Looks Good!</div>
      </div>

      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input
          type="email"
          id="email"
          class="form-control"
          name="email"
          required
        />
      </div>

      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input
          type="password"
          id="password"
          class="form-control"
          name="password"
          required
        />
      </div>

      <button class="btn btn-danger rounded-pill w-100 mb-3">Sign Up</button>

                  <p class="text-center mb-3">
                    Already have an account? 
                    <b><a href="/login" class="text-decoration-none text-danger">Log in</a></b>
                  </p>

    </form>
  </div>
</div>

