<% layout("/layouts/boilerplate.ejs") %>

<div class="row mt-3 shadow rounded-4 w-50 mx-auto">
  <h3 class=" text-center col-10 offset-1 mt-3 mb-0">Welcome back</h3>
  <p class=" text-center col-10 offset-1 small" >Login to your <a href="/listings" class="text-decoration-none text-danger">StayNest</a> account</p>

  <div class="col-10 offset-1">
    <form action="/login" method="POST" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input
          type="text"
          class="form-control"
          name="username"
          id="username"
          required
        />
      </div>

      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input
          type="password"
          id="password"
          class="form-control"
          name="password"
          required
        />
      </div>

      <button class="btn btn-danger rounded-pill w-100 mb-3">Continue</button>

            <p class="text-center mb-3">
              Don't have an account? 
              <b><a href="/signup" class="text-decoration-none text-danger">Sign up</a></b>
            </p>
    </form>
  </div>
</div>

