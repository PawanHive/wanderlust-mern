  <%# navbar %>

<nav class="navbar navbar-expand-lg bg-body-light border-bottom sticky-top">
  <div class="container-fluid flex-wrap gap-2 py-2">

    <%# Brand %>
    <a class="navbar-brand d-flex align-items-center flex-shrink-0" href="/listings">
      <i class="fa-regular fa-compass me-1"></i>
      <span class="navbar-title">StayNest</span>
    </a>

    <%# Search bar — always visible, shrinks on mobile %>
    <form class="d-flex flex-grow-1 search-form" action="/listings" method="GET" style="min-width: 120px; max-width: 400px;">
      <input
        class="form-control me-2 search-input"
        type="text"
        name="search"
        placeholder="Search Destinations"
      />
      <button class="btn search-btn flex-shrink-0" type="submit">
        <i class="fa-solid fa-magnifying-glass"></i>
        <span class="d-none d-sm-inline">Search</span>
      </button>
    </form>

    <%# Toggler — visible only on small screens, placed after search %>
    <button
      class="navbar-toggler flex-shrink-0"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarSupportedContent"
      aria-controls="navbarSupportedContent"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <%# Collapsible section %>
    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <div class="navbar-nav ms-md-auto d-flex flex-column flex-md-row align-items-md-center gap-1 
                  bg-body-tertiary border rounded-3 p-2 p-md-0 border-md-0 bg-md-transparent mt-2 mt-md-0 popup-menu">

        <a class="nav-link" href="/listings/new"><strong>Become a host</strong></a>

        <%# Tax toggle %>
        <div class="tax-toggle px-2">
          <div class="form-check form-switch mb-0 d-flex align-items-center gap-2">
            <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
            <label class="form-check-label" for="flexSwitchCheckDefault">With tax</label>
          </div>
        </div>

        <% if (!currUser) { %>
          <a class="nav-link" href="/signup"><strong>Sign up</strong></a>
          <a class="nav-link" href="/login"><strong>Log in</strong></a>
        <% } %>

        <% if (currUser) { %>
          <a class="nav-link" href="/logout"><strong>Log out</strong></a>
        <% } %>

      </div>
    </div>

  </div>
</nav>